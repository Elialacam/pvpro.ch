{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.pvpro.ch" }],
      "destination": "https://pvpro.ch/:path*",
      "permanent": true
    }
  ]
}
